# Terra Nature Dashboard Configuration
NEXT_PUBLIC_TERRA_API_URL=http://localhost:3000

# Kappa Integration
NEXT_PUBLIC_KAPPA_API_URL=http://localhost:8000
NEXT_PUBLIC_KAPPA_ENABLED=true

# Kappa Configuration (development)
KAPPA_ENV=development
KAPPA_DEBUG=true
KAPPA_MOCK_MODE=true
KAPPA_PORT=8000
KAPPA_HOST=127.0.0.1
KAPPA_LOG_LEVEL=DEBUG

# Data Paths
KAPPA_KB_PATH=./kappa/data/kb.db
KAPPA_MEMORY_PATH=./kappa/data/memory.jsonld
KAPPA_AUDIT_PATH=./kappa/data/audit.jsonl
KAPPA_RULES_PATH=./kappa/rules

# API Keys (required for production, optional in mock mode)
# KAPPA_OPENAI_API_KEY=sk-proj-...
# KAPPA_ANTHROPIC_API_KEY=sk-ant-...

# Security (change in production!)
KAPPA_JWT_SECRET=dev-secret-change-in-production
